# (Run this snippet after install_cron_quality_monitoring.sh; adds aggressive
# repetition audit to the existing QUALITY-MONITORING block.)
PROJECT="/media/praveen/Asthana3/ upgrad/synopysis/FINAL_THESIS_LATEX_EXPERIMENT/singledisease_ASD"
TAG="# QUALITY-MONITORING (asd-dissertation)"
crontab -l > /tmp/crontab.bak 2>/dev/null
crontab -l 2>/dev/null > /tmp/crontab.new
echo "45 11 * * * cd \"$PROJECT\" && python3 scripts/table_jobs/audit_repetition_aggressive.py >> jobs/logs/quality_monitoring.log 2>&1" >> /tmp/crontab.new
echo "45 23 * * * cd \"$PROJECT\" && python3 scripts/table_jobs/audit_repetition_aggressive.py >> jobs/logs/quality_monitoring.log 2>&1" >> /tmp/crontab.new
crontab /tmp/crontab.new
